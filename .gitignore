# typescript — Next.js manages next-env.d.ts and rewrites it on every
# `next build` / `next dev`. The file's own header says "do not edit".
# Tracking it just churns the diff (and Next 15+ adds a reference path
# to the gitignored .next/types/routes.d.ts that some lint configs flag).
next-env.d.ts
